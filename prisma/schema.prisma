// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ProductStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum SunlightRequirement {
  FULL_SUN
  PARTIAL_SUN
  SHADE
}

enum Difficulty {
  BEGINNER
  INTERMEDIATE
  EXPERT
}

model PlantCategory {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  imageUrl    String?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id                       String               @id @default(cuid())
  name                     String
  scientificName           String?
  slug                     String               @unique
  description              String?
  shortDescription         String?
  price                    Float
  discountPrice            Float?
  stock                    Int                  @default(0)
  
  category                 PlantCategory        @relation(fields: [categoryId], references: [id])
  categoryId               String
  
  flowerColor              String?
  flowerType               String?
  sunlightRequirement      SunlightRequirement?
  wateringFrequency        String?
  difficulty               Difficulty?
  bloomSeason              String?
  fertilizerRecommendation String?
  plantHeight              String?
  potSize                  String?
  
  isFeatured               Boolean              @default(false)
  images                   String[]
  tags                     String[]
  
  seoTitle                 String?
  seoDescription           String?
  
  status                   ProductStatus        @default(DRAFT)
  
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt
}

model Achievement {
  id          String    @id @default(cuid())
  title       String
  description String?
  imageUrl    String?
  date        DateTime?
  isFeatured  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Testimonial {
  id               String   @id @default(cuid())
  customerName     String
  story            String
  customerImageUrl String?
  plantImageUrl    String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model GalleryImage {
  id        String   @id @default(cuid())
  title     String?
  imageUrl  String
  tags      String[] // E.g. "Rare", "Terrace View", "Award Ceremony"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
