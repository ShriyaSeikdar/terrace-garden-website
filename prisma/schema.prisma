// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model PlantCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  imageUrl    String?
  plants      Plant[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Plant {
  id                  String        @id @default(cuid())
  name                String
  color               String?
  description         String?
  imageUrl            String?
  isCurrentlyBlooming Boolean       @default(false)
  category            PlantCategory @relation(fields: [categoryId], references: [id])
  categoryId          String
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
}

model Achievement {
  id          String    @id @default(cuid())
  title       String
  description String?
  imageUrl    String?
  date        DateTime?
  isFeatured  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Testimonial {
  id               String   @id @default(cuid())
  customerName     String
  story            String
  customerImageUrl String?
  plantImageUrl    String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model GalleryImage {
  id        String   @id @default(cuid())
  title     String?
  imageUrl  String
  tags      String[] // E.g. "Rare", "Terrace View", "Award Ceremony"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
